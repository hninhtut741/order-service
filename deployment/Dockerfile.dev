FROM node:20-alpine

RUN apk add --no-cache python3 make g++

WORKDIR /app

COPY package*.json ./
COPY . .

RUN npm ci && npm run build && \
    cp -r .next/static .next/standalone/.next/ && \
    cp -r public .next/standalone/ && \
    npm prune --omit=dev

EXPOSE 3001

CMD ["node", ".next/standalone/server.js"]
